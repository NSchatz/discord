{
  "name": "discord-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "deploy-commands:global": "DEPLOY_GLOBAL=true tsx src/deploy-commands.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@napi-rs/canvas": "^0.1.56",
    "@prisma/client": "^6.0.0",
    "discord.js": "^14.16.0",
    "ioredis": "^5.4.0",
    "ms": "^2.1.3",
    "pino": "^9.0.0",
    "shoukaku": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "^22.0.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
