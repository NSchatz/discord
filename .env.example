# Bot (required)
DISCORD_TOKEN=your-bot-token
CLIENT_ID=your-application-client-id
DEV_GUILD_ID=your-test-server-id

# Database (required)
DATABASE_URL=postgresql://bot:password@localhost:5432/discordbot

# Redis
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
NODE_ENV=development

# AI (optional — needed for /ask and /chat)
ANTHROPIC_API_KEY=sk-ant-...

# Music (optional — needed for music commands)
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# Spotify (optional — needed for /artist, /track, /album, /top-tracks, /related)
# Get credentials at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Bot Owner IDs (comma-separated)
OWNER_IDS=your-discord-id
